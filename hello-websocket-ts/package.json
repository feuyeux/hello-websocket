{
  "name": "hello-websocket-ts",
  "version": "1.0.0",
  "description": "Hello WebSocket Protocol - TypeScript implementation",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "server": "node --loader ts-node/esm server/ws_server.ts",
    "client": "node --loader ts-node/esm client/ws_client.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^4.1.10"
  }
}
